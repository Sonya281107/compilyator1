
fn fib(n: i64) -> i64 {
    if n <= 1 {
        return n;
    }
    let mut a: i64 = 0;
    let mut b: i64 = 1;
    let mut i: i64 = 2;
    while i <= n {
        let mut tmp: i64 = a + b;
        a = b;
        b = tmp;
        i = i + 1;
    }
    return b;
}

fn main() {
    let mut i: i64 = 0;
    while i <= 10 {
        print(fib(i));
        i = i + 1;
    }
}
